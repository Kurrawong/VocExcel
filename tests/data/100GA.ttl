.

:pumping
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :boreholeFluidSampling ;
    skos:definition "Pump used to sample surface water"@en ;
    skos:inScheme cs: ;
    skos:narrower
        :pumpingHighFlow ,
