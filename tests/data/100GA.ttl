cs:
    a skos:ConceptScheme ;
    skos:definition "Method by which a physical specimen was obtained, or may indicate that a feature was only observed and not physically sampled. "@en ;
    skos:hasTopConcept
        :airfallDustCollector ,
        :boreholeFluidSampling ,
        :boreholeLoggingTool ,
        :bottleIncubation ,
        :camera ,
        :chamberIncubation ,
        :coreIncubationDark ,
        :coreIncubationLight ,
        :coreVeihmeyerTube ,
        :crushing ,
        :currentMeter ,
