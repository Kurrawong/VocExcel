    skos:inScheme cs: ;
    skos:narrower
        :sidewallCoreBullet ,
        :sidewallCoreMechanical ;
    skos:prefLabel "sidewall core"@en ;
    schema:identifier "sidewallCore"^^xsd:token ;
.

:surfaceMaterialSampling
    a skos:Concept ;
